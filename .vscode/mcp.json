{
  "servers": {
    "mcp-crm": {
      "type": "stdio",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "-m",
        "mcp_crm.drivers.mcp_server"
      ],
      "cwd": "${workspaceFolder}",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "MCP_EMBEDDING_PROVIDER": "sentence-transformers",
        "MCP_LLM_PROVIDER": "stub"
      }
    }
  }
}